rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if user is a manager (custom logic could check a user role field)
    function isManager() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager';
    }

    // Users collection
    match /users/{userId} {
      // Anyone can read user data (simplified for demo)
      allow read: if request.auth != null;
      // Users can only update their own profile
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Expenses collection
    match /expenses/{expenseId} {
      // Employees can read their own expenses, Managers can read all
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isManager());
      
      // Employees can create expenses for themselves
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      // Employees can edit pending expenses, Managers can update status
      allow update: if request.auth != null && (
        (resource.data.userId == request.auth.uid && resource.data.status == 'pending') || 
        isManager()
      );
      
      // Employees can delete their pending expenses
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid && resource.data.status == 'pending';
    }
  }
}
