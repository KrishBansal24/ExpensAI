rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if user is a manager or admin
    function isManager() {
      return request.auth != null &&
        (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        );
    }

    // Users collection (wallet profile)
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isManager());

      // Employee self profile write
      allow create, update: if request.auth != null && request.auth.uid == userId;

      // Manager/Admin can assign wallet and role fields
      allow update: if request.auth != null && isManager();

      // Manager/Admin can archive or remove stale employee profiles
      allow delete: if request.auth != null && isManager();
    }

    // Expenses collection
    match /expenses/{expenseId} {
      // Employees can read their own expenses, Managers can read all
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isManager());
      
      // Employees can create expenses for themselves
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      // Employees can edit pending expenses, Managers can update status
      allow update: if request.auth != null && (
        (resource.data.userId == request.auth.uid && resource.data.status == 'pending') || 
        isManager()
      );
      
      // Employees can delete their pending expenses
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid && resource.data.status == 'pending';
    }

    // Transactions collection (wallet + UPI)
    match /transactions/{transactionId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isManager());

      // Employee can create own UPI transaction
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;

      // Manager can update status (approve/reject)
      allow update: if request.auth != null && isManager();

      // No deletes in demo flow
      allow delete: if false;
    }
  }
}
